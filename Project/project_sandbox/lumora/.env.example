# LUMORA Phase 1.A — ALL OPTIONAL. The mock loop runs with NONE of these set.

# adapter selection (mock works with no keys / no downloads)
EMBEDDER=mock            # mock | bge-m3   (bge-m3 needs sentence-transformers)
GENERATOR=mock           # mock | real     (real needs the keys below)
SOURCE=mock
PUBLISHER=mock

# real-impl credentials (only needed when GENERATOR=real)
# ANTHROPIC_API_KEY=
# REPLICATE_API_TOKEN=

# database — unset = in-memory repo (loop runs WITHOUT docker/postgres)
# set by docker-compose automatically:
# DATABASE_URL=postgresql://lumora:lumora@db:5432/lumora
